# Copy this file to .env.local and fill in your values.
# When Supabase vars are NOT set, the app uses local file-based storage (demo mode).

# ── Supabase (public, read-only — safe for the browser) ──────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service role (SERVER ONLY — never expose to the browser) ─
# Found in: Supabase project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin panel ───────────────────────────────────────────────────────
# Set a strong secret. In dev with no value set, the default token is "dev".
ADMIN_TOKEN=change-me-to-a-strong-secret
